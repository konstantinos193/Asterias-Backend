NODE_ENV=production
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/asterias?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string

# Frontend URL (used for CORS and email links)
FRONTEND_URL=https://asteriashome.gr

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Admin seed credentials
ADMIN_EMAIL=admin@asteriashome.gr
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Booking.com / iCal
ICAL_EXPORT_TOKEN=change-me
BOOKINGCOM_WEBHOOK_SECRET=change-me

# Internal API key
API_KEY=change-me-strong-random-key

# Puppeteer (set by Dockerfile — only override if needed)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
